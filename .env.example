# Database Configuration
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ss54_db

# JWT/Secret Keys
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
MAGIC_LINK_EXPIRE_MINUTES=15

# Frontend URL (for magic links)
FRONTEND_URL=http://localhost:8080

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Admin Panel Settings
ADMIN_ALLOWED_IPS=127.0.0.1,::1
# Generate with: python scripts/generate_admin_password.py "your-password"
ADMIN_PASSWORD_HASH=$2b$12$placeholder-hash-change-this
ADMIN_SESSION_DAYS=7

# File Sync Configuration (Google Drive via Rclone)
# Rclone remote name (configured interactively during deployment)
SYNC_RCLONE_REMOTE=gdrive
# Folder name in Google Drive (will be created if not exists)
SYNC_RCLONE_PATH=ss54-archives
# Rclone config file path on VM
SYNC_RCLONE_CONFIG=/opt/ss54-backend/.rclone.conf
SYNC_RETRY_INTERVAL_MINUTES=15
SYNC_MAX_ATTEMPTS=10
SYNC_BATCH_SIZE=50
